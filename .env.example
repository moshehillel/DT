# Frontend (Vite) environment variables.
# Copy to ".env" for local dev or set these in your CI / hosting build.

# Base URL of your deployed Firebase Cloud Functions, e.g.
# https://us-central1-YOUR_PROJECT.cloudfunctions.net
VITE_FUNCTIONS_BASE_URL=

# Authentication uses Firebase Email/Password — no admin PIN needed.
# Admins are granted the `role: admin` custom claim (see README "First admin").
