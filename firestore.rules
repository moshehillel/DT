rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function isOwnerEmployee(employeeId) {
      return signedIn() && request.auth.uid == employeeId;
    }

    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.servedByEmployeeId == request.auth.uid;
      allow read: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow update: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /inventoryPhones/{phoneId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notificationLogs/{logId} {
      allow read: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow create, update, delete: if isAdmin();
    }

    match /passwordResetRequests/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
