rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appState/{stateId} {
      allow read, write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.servedByEmployeeId == request.auth.uid;
      allow read: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow update: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /pendingReports/{pendingReportId} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if signedIn() && (
        isAdmin()
        || !("claimedBy" in resource.data)
        || resource.data.claimedBy == ""
      );
      allow delete: if signedIn();
    }

    match /phoneOrders/{orderId} {
      allow create: if signedIn();
      allow read: if isAdmin()
        || resource.data.assignedEmployeeId == request.auth.uid;
      allow update: if isAdmin()
        || resource.data.assignedEmployeeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /orderHandlers/{handlerId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /inventoryPhones/{phoneId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notificationLogs/{logId} {
      allow read: if isAdmin()
        || resource.data.servedByEmployeeId == request.auth.uid;
      allow create, update, delete: if isAdmin();
    }

    match /passwordResetRequests/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
