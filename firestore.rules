rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appState/{stateId} {
      allow read, write: if signedIn();
    }

    match /reports/{reportId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /pendingReports/{pendingReportId} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if signedIn() && (
        isAdmin()
        || !("claimedBy" in resource.data)
        || resource.data.claimedBy == ""
      );
      allow delete: if signedIn() && (
        isAdmin()
        || ("claimedBy" in resource.data && resource.data.claimedBy != "")
        || ("servedBy" in resource.data && resource.data.servedBy != "")
        || resource.data.source == "shopify_pos"
      );
    }

    match /phoneOrders/{orderId} {
      allow read, create, update, delete: if signedIn();
    }

    match /orderHandlers/{handlerId} {
      allow read, create, update, delete: if signedIn();
    }

    match /inventoryPhones/{phoneId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notificationLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /passwordResetRequests/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
