{
  "description": "Diamant Telecom - customer repair status lookup by caller ID, phone number, or ticket number",
  "states": [
    {
      "name": "Trigger",
      "type": "trigger",
      "transitions": [
        {
          "event": "incomingCall",
          "next": "main_menu"
        }
      ],
      "properties": {
        "offset": {
          "x": 0,
          "y": 0
        }
      }
    },
    {
      "name": "main_menu",
      "type": "gather-input-on-call",
      "transitions": [
        {
          "event": "keypress",
          "next": "main_menu_split"
        },
        {
          "event": "timeout",
          "next": "say_no_selection"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Welcome to Diamant Telecom. To check your repair or return status, press 1 to use the number you are calling from, press 2 to enter a phone number, or press 3 to enter your repair ticket number.",
        "timeout": 8,
        "num_digits": 1,
        "offset": {
          "x": 220,
          "y": 80
        }
      }
    },
    {
      "name": "main_menu_split",
      "type": "split-based-on",
      "transitions": [
        {
          "event": "match",
          "next": "set_lookup_caller",
          "conditions": [
            {
              "friendly_name": "Use caller ID",
              "arguments": [
                "{{widgets.main_menu.Digits}}"
              ],
              "type": "equal_to",
              "value": "1"
            }
          ]
        },
        {
          "event": "match",
          "next": "gather_phone",
          "conditions": [
            {
              "friendly_name": "Enter phone number",
              "arguments": [
                "{{widgets.main_menu.Digits}}"
              ],
              "type": "equal_to",
              "value": "2"
            }
          ]
        },
        {
          "event": "match",
          "next": "gather_ticket",
          "conditions": [
            {
              "friendly_name": "Enter ticket number",
              "arguments": [
                "{{widgets.main_menu.Digits}}"
              ],
              "type": "equal_to",
              "value": "3"
            }
          ]
        },
        {
          "event": "noMatch",
          "next": "say_invalid_option"
        }
      ],
      "properties": {
        "input": "{{widgets.main_menu.Digits}}",
        "offset": {
          "x": 520,
          "y": 80
        }
      }
    },
    {
      "name": "set_lookup_caller",
      "type": "set-variables",
      "transitions": [
        {
          "event": "next",
          "next": "lookup_repair_status"
        }
      ],
      "properties": {
        "variables": [
          {
            "key": "lookup",
            "value": "{{contact.channel.address}}"
          }
        ],
        "offset": {
          "x": 820,
          "y": 0
        }
      }
    },
    {
      "name": "gather_phone",
      "type": "gather-input-on-call",
      "transitions": [
        {
          "event": "keypress",
          "next": "set_lookup_phone"
        },
        {
          "event": "timeout",
          "next": "say_no_phone_entered"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Enter the customer phone number on file, then press pound.",
        "timeout": 8,
        "finish_on_key": "#",
        "offset": {
          "x": 820,
          "y": 160
        }
      }
    },
    {
      "name": "set_lookup_phone",
      "type": "set-variables",
      "transitions": [
        {
          "event": "next",
          "next": "lookup_repair_status"
        }
      ],
      "properties": {
        "variables": [
          {
            "key": "lookup",
            "value": "{{widgets.gather_phone.Digits}}"
          }
        ],
        "offset": {
          "x": 1120,
          "y": 160
        }
      }
    },
    {
      "name": "gather_ticket",
      "type": "gather-input-on-call",
      "transitions": [
        {
          "event": "keypress",
          "next": "set_lookup_ticket"
        },
        {
          "event": "timeout",
          "next": "say_no_ticket_entered"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Enter the numbers from your repair ticket, then press pound.",
        "timeout": 8,
        "finish_on_key": "#",
        "offset": {
          "x": 820,
          "y": 320
        }
      }
    },
    {
      "name": "set_lookup_ticket",
      "type": "set-variables",
      "transitions": [
        {
          "event": "next",
          "next": "lookup_repair_status"
        }
      ],
      "properties": {
        "variables": [
          {
            "key": "lookup",
            "value": "{{widgets.gather_ticket.Digits}}"
          }
        ],
        "offset": {
          "x": 1120,
          "y": 320
        }
      }
    },
    {
      "name": "lookup_repair_status",
      "type": "make-http-request",
      "transitions": [
        {
          "event": "success",
          "next": "status_found_split"
        },
        {
          "event": "failed",
          "next": "say_lookup_error"
        }
      ],
      "properties": {
        "method": "POST",
        "content_type": "application/json",
        "url": "https://us-central1-diamant-telecom.cloudfunctions.net/repairStatus",
        "parameters": [
          {
            "key": "lookup",
            "value": "{{flow.variables.lookup}}"
          },
          {
            "key": "caller",
            "value": "{{contact.channel.address}}"
          }
        ],
        "offset": {
          "x": 1420,
          "y": 160
        }
      }
    },
    {
      "name": "status_found_split",
      "type": "split-based-on",
      "transitions": [
        {
          "event": "match",
          "next": "say_repair_status",
          "conditions": [
            {
              "friendly_name": "Repair found",
              "arguments": [
                "{{widgets.lookup_repair_status.parsed.found}}"
              ],
              "type": "equal_to",
              "value": "true"
            }
          ]
        },
        {
          "event": "noMatch",
          "next": "say_no_repair_found"
        }
      ],
      "properties": {
        "input": "{{widgets.lookup_repair_status.parsed.found}}",
        "offset": {
          "x": 1720,
          "y": 160
        }
      }
    },
    {
      "name": "say_repair_status",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "gather_next_step"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "{{widgets.lookup_repair_status.parsed.customerMessage}}",
        "offset": {
          "x": 2020,
          "y": 100
        }
      }
    },
    {
      "name": "say_no_repair_found",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "gather_next_step"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Sorry, we could not find a repair using that number. You can try again or stay on the line for the store.",
        "offset": {
          "x": 2020,
          "y": 280
        }
      }
    },
    {
      "name": "gather_next_step",
      "type": "gather-input-on-call",
      "transitions": [
        {
          "event": "keypress",
          "next": "next_step_split"
        },
        {
          "event": "timeout",
          "next": "say_goodbye"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Press 1 to look up another repair. Press 2 to hear phones currently for sale. Press 3 to speak with the store.",
        "timeout": 6,
        "num_digits": 1,
        "offset": {
          "x": 2320,
          "y": 180
        }
      }
    },
    {
      "name": "next_step_split",
      "type": "split-based-on",
      "transitions": [
        {
          "event": "match",
          "next": "main_menu",
          "conditions": [
            {
              "friendly_name": "Look up another",
              "arguments": [
                "{{widgets.gather_next_step.Digits}}"
              ],
              "type": "equal_to",
              "value": "1"
            }
          ]
        },
        {
          "event": "match",
          "next": "say_inventory_transfer_note",
          "conditions": [
            {
              "friendly_name": "Phones for sale",
              "arguments": [
                "{{widgets.gather_next_step.Digits}}"
              ],
              "type": "equal_to",
              "value": "2"
            }
          ]
        },
        {
          "event": "match",
          "next": "connect_store",
          "conditions": [
            {
              "friendly_name": "Speak with store",
              "arguments": [
                "{{widgets.gather_next_step.Digits}}"
              ],
              "type": "equal_to",
              "value": "3"
            }
          ]
        },
        {
          "event": "noMatch",
          "next": "gather_next_step"
        }
      ],
      "properties": {
        "input": "{{widgets.gather_next_step.Digits}}",
        "offset": {
          "x": 2620,
          "y": 180
        }
      }
    },
    {
      "name": "connect_store",
      "type": "connect-call-to",
      "transitions": [
        {
          "event": "callCompleted"
        },
        {
          "event": "hangup"
        }
      ],
      "properties": {
        "noun": "number",
        "to": "+15555555555",
        "caller_id": "{{contact.channel.address}}",
        "offset": {
          "x": 2920,
          "y": 100
        }
      }
    },
    {
      "name": "say_inventory_transfer_note",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Phones for sale are handled by the Diamant Telecom phones for sale flow. Assign another Twilio number to that flow, or connect this option to a subflow after publishing both flows.",
        "offset": {
          "x": 2920,
          "y": 280
        }
      }
    },
    {
      "name": "say_no_selection",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "main_menu"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "I did not get a selection. Let's try again.",
        "offset": {
          "x": 220,
          "y": 320
        }
      }
    },
    {
      "name": "say_invalid_option",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "main_menu"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "That was not a valid option. Let's try again.",
        "offset": {
          "x": 520,
          "y": 320
        }
      }
    },
    {
      "name": "say_no_phone_entered",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "main_menu"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "I did not receive a phone number. Let's try again.",
        "offset": {
          "x": 820,
          "y": 480
        }
      }
    },
    {
      "name": "say_no_ticket_entered",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "main_menu"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "I did not receive a ticket number. Let's try again.",
        "offset": {
          "x": 820,
          "y": 620
        }
      }
    },
    {
      "name": "say_lookup_error",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete",
          "next": "connect_store"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Sorry, the lookup system is not available right now. Please stay on the line and we will connect you with the store.",
        "offset": {
          "x": 1720,
          "y": 360
        }
      }
    },
    {
      "name": "say_goodbye",
      "type": "say-play",
      "transitions": [
        {
          "event": "audioComplete"
        }
      ],
      "properties": {
        "voice": "Polly.Joanna",
        "language": "en-US",
        "say": "Thank you for calling Diamant Telecom. Goodbye.",
        "offset": {
          "x": 2620,
          "y": 420
        }
      }
    }
  ],
  "initial_state": "Trigger",
  "flags": {
    "allow_concurrent_calls": true
  }
}
